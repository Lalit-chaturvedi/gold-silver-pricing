# ── Twilio Credentials ──────────────────────────────────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+

# ── Server Config ────────────────────────────────────────────────────────────
PORT=4000



# ── Frontend URL (for CORS) ──────────────────────────────────────────────────
# Local development:
FRONTEND_URL=http://localhost:5174
# Production (replace with your actual domain):
# FRONTEND_URL=https://yourdomain.com

# ── MSG91 Credentials ───────────────────────────────────────────────────────
# Get Auth Key from: https://dashboard.msg91.com/api/key
MSG91_AUTH_KEY=

# Get Template ID from: MSG91 Dashboard → SMS → Templates
MSG91_TEMPLATE_ID=

# Your approved Sender ID (6 characters)
MSG91_SENDER_ID=GLDSLV

TWOFACTOR_API_KEY=