# ── Twilio Credentials ──────────────────────────────────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Server Config ────────────────────────────────────────────────────────────
PORT=4000

# ── Frontend URL (for CORS) ──────────────────────────────────────────────────
# Local development:
FRONTEND_URL=http://localhost:5174
# Production (replace with your actual domain):
# FRONTEND_URL=https://yourdomain.com

